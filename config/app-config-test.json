{
  "authTokenKey": "secret-gh-token-key",
  "extractDir": "temp",
  "perPage": 100,
  "languages": [
    {
      "name": "TypeScript",
      "extension": ".ts"
    },
    {
      "name": "JavaScript",
      "extension": ".js"
    },
    {
      "name": "HTML",
      "extension": ".html"
    }
  ],
  "packageFile": "package.json",
  "dependencies": [
    "@some/npm-dep"
  ],
  "reposToignore":[
    "ignore-this-repo"
  ],
  "resultsWriterConfig": {
    "destination": "my-scanner-table",
    "destinationType": "table",
    "useBatch": true
  }
}
